# ─── Frontend Environment Variables ─────────────────────────────────────────
# Copiá este archivo como .env.local y completá con tus valores
# NUNCA commitees .env.local al repositorio

# URL de la API Gateway (se obtiene del output de CDK)
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev

# Cognito — se obtienen del output de CDK
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS Region
VITE_AWS_REGION=us-east-1
